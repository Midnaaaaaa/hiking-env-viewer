# This .gitignore file should be placed at the root of your Unity project directory

# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/

# Autogenerated VS/MD/VSCode project files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.exe
*.app
*.msi
*.dll
*.manifest
*.map
*.dSYM.zip
*.dSYM

# Include the necessary build files
!Build/
!Builds/

# Never ignore Asset meta data
!Assets/**/*.meta

# Uncomment this line if you wish to ignore the asset store tools plugin
# [Aa]ssets/AssetStoreTools*

# Unnecessary asset files
[Dd]ebug/

# Mono auto generated files
mono_crash.*

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
ehthumbs.db
[Tt]humbs.db

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.userprefs
*.vscode
.idea/

# Rider
.idea/
*.sln.iml
